NODE_ENV=development
PORT=8080
HOST=127.0.0.1

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=StrongPassword123!
DB_NAME=love_and_flour_lms

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5176
# Add your deployed frontend origin here, for example:
# ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

JWT_ACCESS_SECRET=change_me_change_me_change_me_123
JWT_ACCESS_TTL=15m
JWT_ISSUER=love-and-flour-backend
JWT_AUDIENCE=love-and-flour-web

TOKEN_HASH_SECRET=change_me_change_me_change_me_change_me_123456

ADMIN_BOOTSTRAP_SECRET=
ADMIN_BOOTSTRAP_ENABLED=true

PUBLIC_WEB_BASE_URL=http://localhost:5173
# Set this to your Vercel frontend URL in production.

# Google OAuth
# Create OAuth client in Google Cloud Console (Web application).
# Authorized redirect URI should match backend callback:
#   http://localhost:8080/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Optional override (otherwise derived from request host)
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_COOKIE_NAME=refresh_token
# If frontend and backend are on different domains, use `none` (required for refresh cookies on mobile Safari/Chrome).
# For local dev you can keep `lax`.
AUTH_COOKIE_SAMESITE=none
COOKIE_DOMAIN=
# COOKIE_SECURE=true

# SMTP email delivery
# If SMTP_HOST is set, SMTP_USER + SMTP_PASSWORD are required (production hardening).
#
# Providers (examples):
# - Gmail (requires App Password): SMTP_PROVIDER=gmail, SMTP_USER=you@gmail.com, SMTP_PASSWORD=your_app_password
# - SendGrid: SMTP_PROVIDER=sendgrid, SMTP_USER=apikey, SMTP_PASSWORD=your_sendgrid_api_key
# - Mailgun: SMTP_PROVIDER=mailgun, SMTP_USER=postmaster@YOUR_DOMAIN, SMTP_PASSWORD=your_mailgun_smtp_password
SMTP_PROVIDER=custom
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE=true            # optional override (true=SSL/TLS)
# SMTP_REQUIRE_TLS=true       # optional (force STARTTLS)
SMTP_USER=manpreet24@navgurukul.org
SMTP_PASSWORD=warr dblf wmyv igrk
SMTP_FROM_EMAIL=manpreet24@navgurukul.org
SMTP_FROM_NAME=Love & Flour
SMTP_REQUIRE_TLS = true
CONTACT_TO_EMAIL = manpreet24@navgurukul.org
CONTACT_SUBJECT_PREFIX = [Contact]
# SMTP_TLS_REJECT_UNAUTHORIZED=true

RATE_LIMIT_GENERAL_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=300
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=15
RATE_LIMIT_BOOTSTRAP_WINDOW_MS=600000
RATE_LIMIT_BOOTSTRAP_MAX=5
RATE_LIMIT_PASSWORD_WINDOW_MS=3600000
RATE_LIMIT_PASSWORD_MAX=5
RATE_LIMIT_SEARCH_WINDOW_MS=60000
RATE_LIMIT_SEARCH_MAX=120



# Media storage
STORAGE_PROVIDER=local
MEDIA_LOCAL_ROOT=./uploads
MEDIA_MAX_IMAGE_BYTES=10485760
MEDIA_MAX_PDF_BYTES=26214400
MEDIA_MAX_VIDEO_BYTES=524288000

# Redis (caching + rate limit store)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=laf

# Observability
METRICS_ENABLED=false
METRICS_TOKEN=
HEALTH_DEEP_TOKEN=
WORKER_ENABLED=true

# Optional: serve built frontend from backend (single origin deploy)
# SERVE_FRONTEND=true
# FRONTEND_DIST_PATH=../frontend/loveAndFlour/dist

# Web Push (VAPID)
# Generate keys:
#   npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:no-reply@loveandflour.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
